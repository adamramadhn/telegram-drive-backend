# Telegram API Credentials
# Dapatkan dari https://my.telegram.org/apps

TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Telegram Phone Number
# Format: +6281234567890 (masukkan nomor kamu)

TELEGRAM_PHONE_NUMBER=+628xxxxxxxxx

# Private Channel ID
# Format: -1001234567890 (private channel ID)

TELEGRAM_CHANNEL_ID=-1001234567890

# Session Name (optional, default: telegram_drive)
# TELEGRAM_SESSION_NAME=telegram_drive

# Railway Auto-generated (jangan diubah)
PORT=8000